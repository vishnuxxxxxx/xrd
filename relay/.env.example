# Copy this file to .env and fill in your values.
# Lines starting with # are ignored. No quotes needed unless a value has spaces.

# Port the server listens on
PORT=3000

# --- Telegram bot integration (for Problem Reporting) ---
# 1. Message @BotFather on Telegram, run /newbot, and copy the token it gives you.
# 2. Add your bot to the group/channel you want reports posted to (or message it directly).
# 3. Get the chat id:
#      - For a direct message to the bot: send it any message, then visit
#        https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates and read "chat":{"id": ...}
#      - For a group: add the bot to the group, send a message, then check the same URL.
#      - For a channel: use the channel's @username as the chat id (e.g. @my_channel).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
